# Supabase project URL.
# Hosted example: https://your-project-ref.supabase.co
# Local Supabase CLI default: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key for browser/server auth clients.
# For local Supabase, copy the anon key shown by `supabase status`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional canonical app origin used for OAuth callbacks.
# Example: http://localhost:3000
NEXT_PUBLIC_SITE_URL=
